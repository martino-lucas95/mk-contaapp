# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=contaapp
DB_PASSWORD=contaapp_secret
DB_NAME=contaapp

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generá uno propio: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_64_caracteres_en_produccion
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=otro_secreto_diferente_para_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d

# ── Encriptación AES-256 (credenciales de clientes) ───────────────────────────
# EXACTAMENTE 32 caracteres
ENCRYPTION_KEY=contaapp_dev_key_32bytes_padded!!

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173
