# ─── Base de Datos ───────────────────────────────────────────
DB_NAME=contaapp
DB_USER=contaapp
DB_PASSWORD=contaapp_secret

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change_this_jwt_secret_to_something_long_and_random
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_to_something_long_and_random
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encriptación de credenciales (AES-256, mínimo 32 chars) ─
ENCRYPTION_KEY=change_this_32_char_encryption_key!

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development
VITE_API_URL=http://localhost:3000
